# ── Server ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Security ─────────────────────────────────────────────────────
# Genera un valor seguro con:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_una_cadena_aleatoria_larga_en_produccion

# ── Base de datos ─────────────────────────────────────────────────
# Dejar vacío usa ./db/mendez.db por defecto
DB_PATH=

# ── Email SMTP ────────────────────────────────────────────────────
# Dejar vacío = modo consola (imprime códigos en terminal, útil en dev)
#
# Mailtrap (testing):
#   SMTP_HOST=sandbox.smtp.mailtrap.io  SMTP_PORT=2525
# Gmail:
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_SECURE=false
# SendGrid:
#   SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_USER=apikey
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@mendeztransport.com
